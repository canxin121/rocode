{
  "$schema": "https://rocode.dev/schemas/scheduler-profile.schema.json",
  "version": "2026-03-14",

  "defaults": {
    "profile": "sisyphus-default"
  },

  "profiles": {
    "sisyphus-default": {
      "orchestrator": "sisyphus",
      "description": "OMO-aligned delegation-first scheduler profile. Classify the request, route to the best execution posture, then drive execution to completion in one orchestrated loop.",
      // Optional: override the model used by the scheduler for this profile.
      // Per-agent model (agentTree agent.model) takes precedence over this.
      // If omitted, the session's current model is used as fallback.
      "model": {
        "providerId": "anthropic",
        "modelId": "claude-sonnet-4-20250514"
      },
      "skillList": [
        "request-analysis",
        "route",
        "execution-orchestration"
      ],
      "stages": [
        "request-analysis",
        "route",
        "execution-orchestration"
      ],
      "skillTree": {
        "contextMarkdown": "Route once, preserve request intent, and let the shared execution kernel own the loop until completion."
      },
      "agentTree": {
        "agent": {
          "name": "deep-worker"
        },
        "children": [
          {
            "agent": {
              "name": "code-explorer"
            },
            "prompt": "Map implementation hotspots and collect repository evidence before execution commits to a change."
          },
          {
            "agent": {
              "name": "docs-researcher"
            },
            "prompt": "Bring in external documentation only when it materially changes execution risk or design constraints."
          }
        ]
      }
    },

    // Customized sisyphus variant demonstrating per-stage overrides.
    // Stages can be plain strings (use preset defaults) or objects with
    // per-stage policy overrides — mix freely in the same array.
    //
    // agentTree fields can be inline objects OR file path strings.
    // File paths are resolved relative to this config file's directory.
    "sisyphus-custom": {
      "orchestrator": "sisyphus",
      "description": "Sisyphus with per-stage overrides: bounded execution, read-only route, and a dedicated agent tree loaded from a file.",
      "stages": [
        "request-analysis",
        // Override route: allow tools so it can inspect the project before routing.
        {
          "kind": "route",
          "toolPolicy": "allow-all"
        },
        // Override execution: cap steps, load agent tree from external file.
        {
          "kind": "execution-orchestration",
          "loopBudget": "step-limit:10",
          "childSession": true,
          // File path instead of inline object — loads ./trees/coordinator-tree.json
          "agentTree": "./trees/coordinator-tree.json"
        }
      ],
      // Profile-level agentTree also supports file paths.
      "agentTree": "./trees/deep-worker-tree.jsonc"
    }
  }
}
