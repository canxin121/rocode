{
  "$schema": "https://rocode.dev/schemas/scheduler-profile.schema.json",
  "version": "2026-03-14",

  "defaults": {
    "profile": "pso-3iter"
  },

  "profiles": {
    // ─────────────────────────────────────────────────────────────────────
    // PSO-3iter: Particle Swarm Optimization with 3 iterations
    //
    // Each iteration:
    //   execution-orchestration → 3 particles explore in parallel
    //   synthesis               → coordinator aggregates global-best
    //
    // Because the transcript accumulates, each iteration's particles
    // automatically see the previous synthesis as context — this is the
    // "velocity update" in PSO terms.
    //
    // The same agent tree is shared across all execution stages (particles
    // keep their identity), but their input context evolves each round.
    // ─────────────────────────────────────────────────────────────────────
    "pso-3iter": {
      "orchestrator": "atlas",
      "description": "Particle Swarm Optimization topology: 3 specialized particles (Architect, Empiricist, Adversary) explore independently, converge through iterative synthesis rounds. 3 iterations.",
      "model": {
        "providerId": "anthropic",
        "modelId": "claude-sonnet-4-20250514"
      },
      "stages": [
        // ── Phase 0: Understand the task ──
        "request-analysis",

        // ── Iteration 1: Initial exploration ──
        // Each particle approaches the problem from its unique angle.
        // No prior swarm knowledge — pure independent exploration.
        {
          "kind": "execution-orchestration",
          "loopBudget": "step-limit:12",
          "childSession": true,
          "sessionProjection": "transcript",
          "agentTree": "./trees/pso-swarm.json"
        },
        // Aggregate iteration 1: synthesize a global-best from all particles.
        "synthesis",

        // ── Iteration 2: Reflection + re-exploration ──
        // Particles now see the iteration-1 synthesis in their context.
        // Each particle reflects on the global-best, then explores further
        // from its own cognitive perspective.
        {
          "kind": "execution-orchestration",
          "loopBudget": "step-limit:12",
          "childSession": true,
          "sessionProjection": "transcript",
          "agentTree": "./trees/pso-swarm.json"
        },
        // Aggregate iteration 2.
        "synthesis",

        // ── Iteration 3: Final convergence ──
        // By now the swarm has two rounds of global-best to learn from.
        // Particles make final refinements.
        {
          "kind": "execution-orchestration",
          "loopBudget": "step-limit:12",
          "childSession": true,
          "sessionProjection": "transcript",
          "agentTree": "./trees/pso-swarm.json"
        },
        // Final synthesis: converged result.
        "synthesis"
      ],
      "skillTree": {
        "contextMarkdown": "This scheduler implements a Particle Swarm Optimization pattern. Three cognitive particles — Architect (structural), Empiricist (evidence-based), and Adversary (failure-mode) — independently explore each task, then converge through iterative synthesis. Each particle maintains its unique perspective while incorporating global-best feedback from previous rounds."
      }
    },

    // ─────────────────────────────────────────────────────────────────────
    // PSO-5iter: Higher iteration count for complex tasks
    // ─────────────────────────────────────────────────────────────────────
    "pso-5iter": {
      "orchestrator": "atlas",
      "description": "PSO with 5 iterations for deeply complex tasks requiring thorough convergence.",
      "stages": [
        "request-analysis",
        // Iteration 1
        { "kind": "execution-orchestration", "loopBudget": "step-limit:10", "childSession": true, "sessionProjection": "transcript", "agentTree": "./trees/pso-swarm.json" },
        "synthesis",
        // Iteration 2
        { "kind": "execution-orchestration", "loopBudget": "step-limit:10", "childSession": true, "sessionProjection": "transcript", "agentTree": "./trees/pso-swarm.json" },
        "synthesis",
        // Iteration 3
        { "kind": "execution-orchestration", "loopBudget": "step-limit:10", "childSession": true, "sessionProjection": "transcript", "agentTree": "./trees/pso-swarm.json" },
        "synthesis",
        // Iteration 4
        { "kind": "execution-orchestration", "loopBudget": "step-limit:10", "childSession": true, "sessionProjection": "transcript", "agentTree": "./trees/pso-swarm.json" },
        "synthesis",
        // Iteration 5 — final
        { "kind": "execution-orchestration", "loopBudget": "step-limit:8", "childSession": true, "sessionProjection": "transcript", "agentTree": "./trees/pso-swarm.json" },
        "synthesis"
      ],
      "skillTree": {
        "contextMarkdown": "PSO-5iter: 5 convergence rounds. Use for tasks where 3 iterations is insufficient — e.g. large-scale architecture decisions, complex refactoring, multi-system integration design."
      }
    }
  }
}
