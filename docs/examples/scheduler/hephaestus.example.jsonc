{
  "$schema": "https://rocode.dev/schemas/scheduler-profile.schema.json",
  "version": "2026-03-14",

  "defaults": {
    "profile": "hephaestus-default"
  },

  "profiles": {
    "hephaestus-default": {
      "orchestrator": "hephaestus",
      "description": "OMO-aligned autonomous execution scheduler profile. Keep orchestration overhead low, execute deeply, and verify concretely before finishing.",
      // Optional: override the model used by the scheduler for this profile.
      // Deep autonomous execution benefits from strong coding models.
      "model": {
        "providerId": "openai",
        "modelId": "gpt-5.2"
      },
      "skillList": [
        "request-analysis",
        "execution-orchestration"
      ],
      "stages": [
        "request-analysis",
        "execution-orchestration"
      ],
      "skillTree": {
        "contextMarkdown": "Prefer direct execution over extra coordination layers, but keep verification discipline high before settling the result."
      },
      "agentTree": {
        "agent": {
          "name": "deep-worker"
        }
      }
    },

    // Customized hephaestus variant demonstrating per-stage overrides.
    // Adds a bounded execution budget and synthesis stage.
    "hephaestus-custom": {
      "orchestrator": "hephaestus",
      "description": "Hephaestus with bounded execution, custom deep-worker tree, and synthesis.",
      "stages": [
        "request-analysis",
        // Override execution: stricter budget, dedicated agent tree with test writer.
        {
          "kind": "execution-orchestration",
          "loopBudget": "step-limit:15",
          "childSession": true,
          "agentTree": {
            "agent": {
              "name": "autonomous-executor",
              "maxSteps": 12,
              "model": { "providerId": "anthropic", "modelId": "claude-sonnet-4-20250514" }
            },
            "children": [
              {
                "agent": { "name": "test-writer", "allowedTools": ["read", "glob", "grep", "bash"] },
                "prompt": "Write tests for every change before the main executor marks it done."
              }
            ]
          }
        },
        // Add synthesis to ensure clean output formatting.
        "synthesis"
      ]
    }
  }
}
