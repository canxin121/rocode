{
  "$schema": "https://rocode.dev/schemas/scheduler-profile.schema.json",
  "version": "2026-03-14",

  "defaults": {
    "profile": "atlas-default"
  },

  "profiles": {
    "atlas-default": {
      "orchestrator": "atlas",
      "description": "OMO-aligned coordination scheduler profile. Break execution into owned workstreams, coordinate progress, and synthesize the converged result.",
      // Optional: override the model used by the scheduler for this profile.
      // Coordination benefits from strong instruction-following.
      "model": {
        "providerId": "anthropic",
        "modelId": "claude-sonnet-4-20250514"
      },
      "skillList": [
        "request-analysis",
        "execution-orchestration",
        "synthesis"
      ],
      "stages": [
        "request-analysis",
        "execution-orchestration",
        "synthesis"
      ],
      "skillTree": {
        "contextMarkdown": "Preserve task ownership boundaries, coordinate parallel work deliberately, and do not claim completion until the synthesized result converges."
      },
      "agentTree": {
        "agent": {
          "name": "deep-worker"
        },
        "children": [
          {
            "agent": {
              "name": "code-explorer"
            },
            "prompt": "Own code-facing exploration and implementation evidence for one workstream at a time."
          },
          {
            "agent": {
              "name": "docs-researcher"
            },
            "prompt": "Own documentation and external evidence gathering for dependent APIs, libraries, or product constraints."
          },
          {
            "agent": {
              "name": "architecture-advisor"
            },
            "prompt": "Check that parallel workstreams still converge on one authority and one coherent final synthesis."
          }
        ]
      }
    },

    // Customized atlas variant demonstrating per-stage overrides.
    // Atlas with a review stage inserted and per-stage agent trees.
    "atlas-custom": {
      "orchestrator": "atlas",
      "description": "Atlas with review stage, bounded execution, and separate agent trees for execution vs review.",
      "stages": [
        "request-analysis",
        // Bounded execution with a 3-worker parallel tree.
        {
          "kind": "execution-orchestration",
          "loopBudget": "step-limit:8",
          "childSession": true,
          "agentTree": {
            "agent": { "name": "parallel-coordinator" },
            "children": [
              {
                "agent": { "name": "worker-a", "allowedTools": ["read", "glob", "grep", "bash"] },
                "prompt": "Own workstream A."
              },
              {
                "agent": { "name": "worker-b", "allowedTools": ["read", "glob", "grep", "bash"] },
                "prompt": "Own workstream B."
              },
              {
                "agent": { "name": "worker-c", "allowedTools": ["read", "glob", "grep", "bash"] },
                "prompt": "Own workstream C."
              }
            ]
          }
        },
        // Add a review stage (not in default atlas) with security focus.
        {
          "kind": "review",
          "toolPolicy": "allow-read-only",
          "agentTree": {
            "agent": { "name": "qa-reviewer" },
            "children": [
              { "agent": { "name": "security-checker" }, "prompt": "OWASP Top 10 audit." }
            ]
          }
        },
        // Synthesis uses profile-level defaults (hidden stage, no tools).
        "synthesis"
      ],
      // Fallback profile-level agent tree for stages without a per-stage override.
      "agentTree": {
        "agent": { "name": "deep-worker" }
      }
    }
  }
}
