{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rocode.dev/schemas/context-docs-index.schema.json",
  "title": "ROCode Context Docs Index",
  "description": "Docs index file consumed by the context_docs tool for query_docs and get_page.",
  "type": "object",
  "additionalProperties": false,
  "required": ["pages"],
  "properties": {
    "libraryId": {
      "type": "string",
      "minLength": 1,
      "description": "Canonical library id. If present, it must match the registry entry that points to this index."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Default version for pages in this index when a page does not declare its own version."
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/page"
      }
    }
  },
  "$defs": {
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pageId", "title", "url", "content"],
      "properties": {
        "pageId": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical page identifier used by get_page."
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Human-facing page title."
        },
        "url": {
          "type": "string",
          "minLength": 1,
          "format": "uri",
          "description": "Canonical page URL."
        },
        "content": {
          "type": "string",
          "minLength": 1,
          "description": "Plain text page body indexed for search and returned by get_page."
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "Optional short summary used as the preferred search snippet."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Optional per-page version override."
        },
        "headings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Section headings used by scoring and display."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": [],
          "description": "Free-form tags used by scoring and filtering."
        }
      }
    }
  }
}
